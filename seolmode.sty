%% \seolfa{단어} 형태로 사용
%% 출력 모드는 \seolmode 값으로 제어
% 1=그대로 출력
% 2=( 글자 숨김 ), 학생용 빈칸
% 3=( 붉게 강조 ), 답안배포용
% 4=( 붉게 강조 ) 및 메모 노출, 교사용

% 텍스트/수식 모두 안전하게 한 덩어리로 묶는 박스 만들기
% mbox는 텍스트만 됨. 줄바꿈을 막기 위해 한 덩어리 취급하는 박스 제작
\newcommand{\nobreakbox}[1]{\ifmmode\mathchoice
      {\hbox{$\displaystyle #1$}}
      {\hbox{$\textstyle #1$}}
      {\hbox{$\scriptstyle #1$}}
      {\hbox{$\scriptscriptstyle #1$}}\else\mbox{#1}\fi}

\newcount\seolmode
% 진짜 투명 형광펜과 진짜 투명 글씨는 똑같이 자리차지를 안해서 흰글씨와 흰형광펜을 사용중임
\newcommand{\seolfa}[1]{% a는 괄호가 있음. 하나의 덩어리로 묶어서 줄바꿈 되지 않게 함.
  \ifnum\seolmode=1
    \nobreakbox{\hly{\bd{#1}}}% 노랑 형광펜과 bold 글씨
  \else\ifnum\seolmode=2
    \nobreakbox{(\quad \hlp{\white{\bd{#1}}} \quad)}% 투명 형광펜과 흰색 bold 글씨 - 형광펜을 또 해줘야 위아래 폭 동일함
  \else\ifnum\seolmode=3
    \nobreakbox{\red{(\quad \hly{\bd{#1}} \quad)}}% 빨간 형광펜과 bold 글씨
  \else\ifnum\seolmode=4
    \nobreakbox{\red{(\quad \hly{\bd{#1}} \quad)}}\fi\fi\fi\fi}

\newcommand{\seolfb}[1]{% b는 괄호가 없음. 표 안의 내용 등에 활용. 줄바꿈 가능
  \ifnum\seolmode=1
    \hly{\bd{#1}}% 노랑 형광펜과 bold 글씨
  \else\ifnum\seolmode=2
    \hlp{\white{\bd{#1}}}% 투명 형광펜과 투명 bold 글씨
  \else\ifnum\seolmode=3
    \hly{\red{\bd{#1}}}% 빨간 형광펜과 bold 글씨
  \else\ifnum\seolmode=4
    \hly{\red{\bd{#1}}}\fi\fi\fi\fi}

%% 교사용 녹색 하이라이트 (seolmode가 4일 때는 \hll(라임형광펜), 나머지는 \hlp(투명) - 똑같이 여백 차지
\newcommand{\seoli}[1]{%
  \ifnum\seolmode=4 \hll{#1}%
  \else \hlp{#1}\fi}

%% memo 마커 (seolmode가 4일 때만 출력하고 1,2,3일때는 투명처리, 공간을 똑같이 차지해야 함)
% 페이지가 밀리는 경우 메모 위치가 함께 밀릴 수 있으나 컴파일 두 번하면 제대로 배치됨.
% 박스가 밀려나지 않게 안쪽으로 shift 함
\newcommand{\memo}[2][0]{% [#1]: 추가 이동량 multiplier(기본값 0), #2: 메모 내용
  \leavevmode\nopagebreak % 페이지 찢어짐 방지
  \begingroup
  % seolmode 4 전용 출력 설정
  \ifnum\seolmode=4\relax \def\memoDraw{\renderMemoBox{#2}}%
  \else \def\memoDraw{\phantom{\renderMemoBox{#2}}}\fi
  % 위치 마킹
  \stepcounter{memomark}%
  \tikz[remember picture, baseline]{\coordinate (memomark-\thememomark) at (0,0);}%
  % 개별 보정량(#1 * \bs)을 계산에 전달
  \MeasureHalfFrom{\memoDraw}%
  \CoordsHere{memomark-\thememomark}{#1\bs}%
  \ClampFromCoords
  % 모든 이동량(Base + Manual + Clamp)을 합산하여 노드 배치
  \nopagebreak 
  \zz[-\bs] \tikz[remember picture, overlay]{%
    \checkoddpage
    \ifoddpage% 최종 yshift = (전역기본) + (사용자개별) + (경계면보정)
      \node[anchor=center, yshift=\dimexpr\MemoBaseShift + #1\bs + \yshiftEdge\relax] 
        at ($(current page.east |- memomark-\thememomark) + (-85.4pt,0)$) {\memoDraw};
    \else
      \node[anchor=center, yshift=\dimexpr\MemoBaseShift + #1\bs + \yshiftEdge\relax] 
        at ($(current page.west |- memomark-\thememomark) + (85.4pt,0)$) {\memoDraw};
    \fi}\endgroup\nopagebreak\ignorespaces}

% 교사용 페이지 삽입 명령 - 3 이상일 때 노출됨
\newcommand{\insertTeacherPages}[2]{%
  \ifnum\seolmode>2
    \clearpage
    \thispagestyle{empty}
    {\centering\red{\Large\bd{[ 교사용 페이지(양면) 1/2 ]}} \par}
    \vspace{1em}
    \normalsize #1
    \clearpage
    \thispagestyle{empty}
    {\centering\red{\Large\bd{[ 교사용 페이지(양면) 2/2 ]}} \par}
    \vspace{1em}
    \normalsize #2
    \clearpage
    \addtocounter{page}{-2}\fi}% 페이지 카운트 2 다시 제거(원래대로 돌리기)
